    {
      "name": "Favorites",
      "item": [
        {
          "name": "Add Favorite Place",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"placeId\": \"ChIJN1blQLgOZkgRqstts5IHx8c\",\n  \"name\": \"Google Sydney\",\n  \"address\": \"Sydney NSW 2000, Australia\",\n  \"latitude\": -33.866,\n  \"longitude\": 151.193\n}"
            },
            "url": {
              "raw": "http://localhost:8081/api/favorites",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "8081",
              "path": [
                "api",
                "favorites"
              ]
            },
            "description": "Add a new favorite place. Returns 201 on success, 409 if already favorited."
          }
        },
        {
          "name": "Get All Favorites",
          "request": {
            "method": "GET",
            "url": {
              "raw": "http://localhost:8081/api/favorites",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "8081",
              "path": [
                "api",
                "favorites"
              ]
            },
            "description": "Retrieve all favorite places sorted by creation date (newest first)"
          }
        },
        {
          "name": "Get Favorite by Place ID",
          "request": {
            "method": "GET",
            "url": {
              "raw": "http://localhost:8081/api/favorites/ChIJN1blQLgOZkgRqstts5IHx8c",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "8081",
              "path": [
                "api",
                "favorites",
                "ChIJN1blQLgOZkgRqstts5IHx8c"
              ]
            },
            "description": "Get a single favorite place by its Google Places ID"
          }
        },
        {
          "name": "Check Favorite Status",
          "request": {
            "method": "GET",
            "url": {
              "raw": "http://localhost:8081/api/favorites/check/ChIJN1blQLgOZkgRqstts5IHx8c",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "8081",
              "path": [
                "api",
                "favorites",
