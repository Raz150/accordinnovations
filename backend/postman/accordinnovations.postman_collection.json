        },
        {
          "name": "Remove Favorite",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "http://localhost:8081/api/favorites/ChIJN1blQLgOZkgRqstts5IHx8c",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "8081",
              "path": [
                "api",
                "favorites",
                "ChIJN1blQLgOZkgRqstts5IHx8c"
              ]
            },
            "description": "Remove a place from favorites"
          }
        }
